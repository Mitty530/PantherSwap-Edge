# API Keys
PANTHERSWAP_MARKET_DATA_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
PANTHERSWAP_MARKET_DATA_IEX_CLOUD_API_KEY=your_iex_cloud_key

# Alpaca API Keys (Paper Trading)
PANTHERSWAP_MARKET_DATA_ALPACA_API_KEY=your_alpaca_api_key
PANTHERSWAP_MARKET_DATA_ALPACA_SECRET_KEY=your_alpaca_secret_key

# Server Configuration
PANTHERSWAP_SERVER_PORT=8080
PANTHERSWAP_DEBUG=true

# Trading Configuration
PANTHERSWAP_TRADING_ENABLE_LIVE_TRADING=false
