# PantherSwap Edge Environment Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgres://user:password@host:port/database?sslmode=require

# IG Trading API Configuration
IG_TRADING_API_KEY=your_ig_trading_api_key_here
IG_TRADING_USERNAME=your_ig_trading_username_here
IG_TRADING_PASSWORD=your_ig_trading_password_here
IG_TRADING_SECURITY_TOKEN=your_ig_trading_security_token_here
IG_TRADING_CST=your_ig_trading_cst_token_here

# Application Configuration
RUST_LOG=info,sqlx=warn,hyper=warn
ENVIRONMENT=development

# Security Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
API_KEY=your_api_key_for_authentication

# Optional: Override configuration file settings
# SERVER_PORT=8080
# SERVER_HOST=0.0.0.0
# TRADING_ENABLE_LIVE_TRADING=false
# TRADING_MAX_POSITION_SIZE=50000.0
# RISK_MAX_PORTFOLIO_VAR=0.02
# RISK_MAX_DAILY_LOSS=25000.0
# AI_ENABLE_PREDICTIONS=true
