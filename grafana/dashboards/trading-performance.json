{
  "dashboard": {
    "id": null,
    "title": "PantherSwap Edge - Trading Performance",
    "tags": ["pantherswap", "trading", "performance"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "10s",
    "time": {
      "from": "now-30m",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Orders Per Second",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(pantherswap_edge_orders_total[1m])",
            "legendFormat": "Orders/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 100},
                {"color": "green", "value": 1000}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Order Execution Latency",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(pantherswap_edge_order_execution_duration_seconds_bucket[5m])) * 1000",
            "legendFormat": "p95 Latency (ms)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Active Positions",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(pantherswap_edge_active_positions)",
            "legendFormat": "Total Positions"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Portfolio Value",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(pantherswap_edge_portfolio_value_usd)",
            "legendFormat": "Total Value USD"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Order Execution Timeline",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(pantherswap_edge_order_execution_duration_seconds_bucket[1m])) * 1000",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(pantherswap_edge_order_execution_duration_seconds_bucket[1m])) * 1000",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(pantherswap_edge_order_execution_duration_seconds_bucket[1m])) * 1000",
            "legendFormat": "p99"
          }
        ],
        "yAxes": [
          {
            "label": "Milliseconds",
            "min": 0,
            "max": 20
          }
        ],
        "alert": {
          "conditions": [
            {
              "query": {
                "queryType": "",
                "refId": "A"
              },
              "reducer": {
                "type": "last",
                "params": []
              },
              "evaluator": {
                "params": [10],
                "type": "gt"
              }
            }
          ],
          "executionErrorState": "alerting",
          "noDataState": "no_data",
          "frequency": "10s",
          "handler": 1,
          "name": "High Order Latency",
          "message": "Order execution latency is above 10ms"
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 6,
        "title": "Trading Volume by Instrument",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(pantherswap_edge_orders_total[5m])",
            "legendFormat": "{{instrument}}"
          }
        ],
        "yAxes": [
          {
            "label": "Orders/sec",
            "min": 0
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 7,
        "title": "P&L Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "pantherswap_edge_pnl_total_usd",
            "legendFormat": "{{account}} {{period}}"
          }
        ],
        "yAxes": [
          {
            "label": "USD",
            "min": null
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 8,
        "title": "Risk Alerts",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(pantherswap_edge_risk_alerts_total[5m])",
            "legendFormat": "{{alert_type}} {{severity}}"
          }
        ],
        "yAxes": [
          {
            "label": "Alerts/sec",
            "min": 0
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 9,
        "title": "Trading Signals Generated",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(pantherswap_edge_trading_signals_generated_total[5m])",
            "legendFormat": "{{signal_type}} {{instrument}}"
          }
        ],
        "yAxes": [
          {
            "label": "Signals/sec",
            "min": 0
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24}
      }
    ],
    "templating": {
      "list": [
        {
          "name": "instrument",
          "type": "query",
          "query": "label_values(pantherswap_edge_orders_total, instrument)",
          "refresh": 1,
          "multi": true,
          "includeAll": true
        },
        {
          "name": "account",
          "type": "query",
          "query": "label_values(pantherswap_edge_portfolio_value_usd, account)",
          "refresh": 1
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "High Risk Events",
          "datasource": "prometheus",
          "expr": "increase(pantherswap_edge_risk_alerts_total{severity=\"critical\"}[1m]) > 0"
        }
      ]
    }
  }
}
