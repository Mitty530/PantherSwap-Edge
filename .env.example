# AI Configuration
PANTHERSWAP_AI_ENABLE_PREDICTIONS=true
PANTHERSWAP_AI_MODEL_PATH=./models/

# Logging
RUST_LOG=info,sqlx=warn,hyper=warn,tower_http=info
